{
  "title": "EnterpriseIDP — Platform Overview",
  "uid": "idp-overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API — Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(aspnetcore_http_server_request_duration_seconds_count[1m]))",
        "legendFormat": "req/s"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 10 },
          { "color": "red", "value": 50 }
        ]}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API — p95 Latency (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(aspnetcore_http_server_request_duration_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "p95 ms"
      }],
      "options": { "colorMode": "background", "unit": "ms" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 500 },
          { "color": "red", "value": 2000 }
        ]}}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API — Error Rate %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(aspnetcore_http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / sum(rate(aspnetcore_http_server_request_duration_seconds_count[5m])) * 100",
        "legendFormat": "error %"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 5 }
        ]}}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Process Memory (MB)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "dotnet_process_memory_working_set_bytes{otel_scope_name=\"System.Runtime\"} / 1024 / 1024",
        "legendFormat": "MB"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "decmbytes", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 256 },
          { "color": "red", "value": 512 }
        ]}}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (http_route) (rate(aspnetcore_http_server_request_duration_seconds_count[1m]))",
        "legendFormat": "{{ http_route }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(aspnetcore_http_server_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(aspnetcore_http_server_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(aspnetcore_http_server_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": ".NET GC Collections",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (gc_heap_generation) (rate(dotnet_gc_collections_total[1m]))",
        "legendFormat": "{{ gc_heap_generation }}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Thread Pool Queue Length",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "dotnet_thread_pool_queue_length_total{otel_scope_name=\"System.Runtime\"}",
        "legendFormat": "queue length"
      },
      {
        "expr": "dotnet_thread_pool_thread_count_total{otel_scope_name=\"System.Runtime\"}",
        "legendFormat": "thread count"
      }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "PostgreSQL — Active Connections",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{
        "expr": "pg_stat_activity_count{job=\"postgres\"}",
        "legendFormat": "{{ state }}"
      }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Redis — Connected Clients",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [{
        "expr": "redis_connected_clients{job=\"redis\"}",
        "legendFormat": "clients"
      },
      {
        "expr": "rate(redis_commands_processed_total{job=\"redis\"}[1m])",
        "legendFormat": "commands/s"
      }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    }
  ]
}
